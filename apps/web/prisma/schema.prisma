generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Multi-tenant identity & access models
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  slug String @unique

  logoUrl  String?
  settings Json?

  stores       Store[]
  memberships  Membership[]
  invites      Invite[]
  emailSources EmailSource[]
}

model Profile {
  id        String   @id // matches Supabase auth.users.id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String
  fullName  String?
  avatarUrl String?

  memberships    Membership[]
  invitesSent    Invite[]       @relation("InvitedBy")
  platformAdmin  PlatformAdmin?
}

model PlatformAdmin {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  grantedBy String?
  notes     String?
}

model Membership {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profileId      String
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  role String // org_admin | store_admin | manager | viewer

  storeMemberships StoreMembership[]

  @@unique([organizationId, profileId])
  @@index([profileId])
}

model StoreMembership {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([membershipId, storeId])
  @@index([storeId])
}

model Invite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email    String
  role     String // org_admin | store_admin | manager | viewer
  storeIds String[] @default([])

  invitedById String
  invitedBy   Profile @relation("InvitedBy", fields: [invitedById], references: [id])

  token     String    @unique @default(uuid())
  expiresAt DateTime
  acceptedAt DateTime?

  @@index([email])
  @@index([token])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Core business models
// ---------------------------------------------------------------------------

model Store {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name String
  abbreviation String?
  timezone String?

  tekionDealerId String?
  apiSyncEnabled Boolean @default(false)

  advisors       Advisor[]
  ingestionRuns  IngestionRun[]
  ingestedFiles  IngestedFile[]
  rawReportRows  RawReportRow[]
  dailyMetrics   AdvisorDailyMetrics[]
  dailyCommodity AdvisorDailyCommodity[]
  emailSources   EmailSource[]
  storeMemberships StoreMembership[]
  syncRuns         SyncRun[]
  rawRepairOrders  RawRepairOrder[]
  opcodeCategories OpcodeCategory[]

  @@unique([abbreviation])
  @@index([organizationId])
}

model Advisor {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  nameNormalized String
  nameRaw        String?

  tekionUserId String?
  // Tekion userRoleDetails.primaryRole.persona (SERVICE_ADVISOR, SERVICE_MANAGER,
  // WARRANTY_CLERK, CASHIER, TECHNICIAN, ...). NULL for email-sourced advisors
  // (SCVW/ARSJ) and any API advisor not yet resolved.
  persona String?

  dailyMetrics   AdvisorDailyMetrics[]
  dailyCommodity AdvisorDailyCommodity[]

  @@unique([storeId, nameNormalized])
  @@index([storeId])
}

model IngestionRun {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  businessDate DateTime
  batchNo      Int

  status       String   @default("COMPLETED") // COMPLETED | COMPLETED_WITH_WARNINGS | FAILED
  warnings     Json?
  errors       Json?
  summary      Json?

  files        IngestedFile[]
  rawReportRows RawReportRow[]

  @@unique([storeId, batchNo])
  @@index([storeId, businessDate])
}

model IngestedFile {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  runId          String
  run            IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  businessDate   DateTime

  originalFilename String
  sha256           String
  byteSize         Int?

  detectedType       String?
  detectionConfidence Float?
  rawMeta             Json?

  parseWarnings Json?
  parseErrors   Json?

  rawRows RawReportRow[]

  @@index([runId])
  @@index([storeId, businessDate])
  @@unique([runId, sha256])
}

model RawReportRow {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId      String
  store        Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  runId        String
  run          IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ingestedFileId String
  ingestedFile   IngestedFile @relation(fields: [ingestedFileId], references: [id], onDelete: Cascade)
  businessDate  DateTime

  rowIndex Int
  rowHash  String
  data     Json

  @@unique([ingestedFileId, rowIndex])
  @@index([storeId, businessDate])
  @@index([ingestedFileId])
  @@index([rowHash])
}

model AdvisorDailyMetrics {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId      String
  store        Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  advisorId    String
  advisor      Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  businessDate DateTime

  openRos Int @default(0)

  menuCount      Int   @default(0)
  menuLaborGross Float @default(0)
  menuPartsGross Float @default(0)

  alaCount      Int   @default(0)
  alaLaborGross Float @default(0)
  alaPartsGross Float @default(0)

  recCount      Int   @default(0)
  recSoldCount  Int   @default(0)
  recAmount     Float @default(0)
  recSoldAmount Float @default(0)

  dailyLaborGross Float @default(0)
  dailyPartsGross Float @default(0)

  meta Json?

  @@unique([storeId, advisorId, businessDate])
  @@index([storeId, businessDate])
  @@index([storeId, advisorId, businessDate])
}

model AdvisorDailyCommodity {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId      String
  store        Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  advisorId    String
  advisor      Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  businessDate DateTime

  commodityKey String
  qty          Float @default(0)
  gross        Float @default(0)
  laborGross   Float @default(0)

  meta Json?

  @@unique([storeId, advisorId, businessDate, commodityKey])
  @@index([storeId, businessDate])
  @@index([storeId, advisorId, businessDate])
}

model EmailSource {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Optional per-store override. NULL = org-wide source (the typical case:
  // a single DMS sender like reportbuilder@tekion.com routes to all stores
  // in the org via filename abbreviation matching).
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  senderEmail     String
  subjectPattern  String?
  isActive        Boolean   @default(true)
  lastProcessedAt DateTime?

  @@unique([organizationId, senderEmail])
  @@index([organizationId])
  @@index([senderEmail])
  @@index([storeId])
}

// ---------------------------------------------------------------------------
// Audit log — append-only record of sensitive admin actions
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  actorId    String
  actorEmail String
  action     String  // e.g. org.create, store.create, member.role_change, member.remove, invite.create
  targetType String  // e.g. organization, store, membership, invite
  targetId   String

  organizationId String?
  metadata       Json?

  @@index([organizationId, createdAt])
  @@index([actorId])
  @@index([action])
}

// ---------------------------------------------------------------------------
// Tekion OpenAPI pipeline (parallel to the email/Excel ingest)
// ---------------------------------------------------------------------------

model SyncRun {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  kind        String   // FULL_BACKFILL | INCREMENTAL | MANUAL
  windowStart DateTime
  windowEnd   DateTime
  cursor      String?  // modifiedTime watermark (epoch-ms string) for next incremental

  status       String   @default("RUNNING") // RUNNING | COMPLETED | COMPLETED_WITH_WARNINGS | FAILED
  apiCallCount Int      @default(0)
  rosFetched   Int      @default(0)

  warnings Json?
  errors   Json?
  summary  Json?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  rawRepairOrders RawRepairOrder[]

  @@index([storeId, windowStart])
  @@index([storeId, status])
}

model RawRepairOrder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  fetchedAt DateTime @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  syncRunId String?
  syncRun   SyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  documentId     String   // Tekion internal RO id (stable natural key)
  documentNumber String   // RO number shown to users
  status         String?
  payType        String?
  advisorTekionId String?
  vin            String?

  openDate     DateTime?
  closeDate    DateTime?
  businessDate DateTime    // date dimension (midnight UTC) for daily aggregation

  payload     Json    // full RO incl. nested jobs/operations/parts snapshot
  contentHash String  // sha256 of payload for idempotent upsert / change detection

  @@unique([storeId, documentId])
  @@index([storeId, businessDate])
  @@index([syncRunId])
}

model OpcodeCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // storeId NULL = global default; non-null = store-specific override
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  opcode   String
  category String  // MENU | ALA | REC | COMMODITY
  commodityKey String?  // when category=COMMODITY, e.g. "tires", "alignment"

  @@unique([storeId, opcode])
  @@index([category])
}
