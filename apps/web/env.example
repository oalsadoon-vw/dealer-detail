# Database — Supabase Postgres connection strings
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?schema=public"

# Supabase Auth — required for login (anon key is public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase service role key — required for sending invite emails via
# `auth.admin.inviteUserByEmail`. Get it from:
#   Supabase Dashboard → Project Settings → API → Project API keys → service_role
# WARNING: bypasses RLS. NEVER prefix with NEXT_PUBLIC_ and never commit.
SUPABASE_SERVICE_ROLE_KEY=""

# Public URL of the deployed app — used as the redirect target inside
# invite / magic-link emails. Locally this can stay empty and we fall
# back to http://localhost:3000. In production set this to your domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Gmail ingestion — required for cron email ingest
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# Cron security — required for /api/cron/gmail-ingest
CRON_SECRET=""
